# ローカル開発では .env.local にコピーして値を埋める。
# 本番環境（Vercel）はダッシュボードで同名の環境変数を登録する。
# NEXT_PUBLIC_ 接頭辞はブラウザバンドルに含まれる点に注意。

# --- サイト URL ---
# 絶対 URL が必要な場所（マジックリンクリダイレクトなど）で参照する。
# 未設定なら VERCEL_URL（Vercelが自動注入）→ http://localhost:3000 の順でフォールバック。
# 本番では https://1968.love を指定する（Vercel 環境変数で上書き）。
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase ---
# Supabase ダッシュボード > Project Settings > API Keys から取得。
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 管理操作用。サーバーサイドでのみ使用し、絶対にブラウザへ露出させない。
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe（正会員サブスクリプション）---
# Stripe > Developers > API keys から取得、test mode と live mode で値が異なる
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Stripe > Developers > Webhooks で endpoint 作成時に発行される署名シークレット
STRIPE_WEBHOOK_SECRET=
# Stripe > Products > 正会員 配下の各 Price ID
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=

# --- Resend（フェーズ7で使用） ---
RESEND_API_KEY=

# --- Sentry（セキュリティ強化フェーズで使用） ---
SENTRY_DSN=

# --- アクセス解析（本番環境のみ発火）---
# Microsoft Clarity（ヒートマップ・録画）、https://clarity.microsoft.com/ のプロジェクト ID
NEXT_PUBLIC_CLARITY_PROJECT_ID=
# Google Analytics 4 測定 ID、形式 G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=
